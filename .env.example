# =========================
# SERVIDOR LOCAL / CLOUD
# =========================
HOST=0.0.0.0
PORT=8000

# =========================
# SCHEDULER 24/7
# =========================
SCAN_INTERVAL_MINUTES=30
RUN_SCAN_ON_STARTUP=true

# =========================
# SCANNER
# =========================
SIGNAL_MIN_LEVEL=1
ALERT_MIN_LEVEL=3
MAX_SIGNALS_PER_SCAN=30
PERIODO_DATOS=6mo
INTERVALO_DATOS=1d
MIN_DATA_ROWS=80

# =========================
# FUENTES DE DATOS
# =========================
TWELVE_DATA_API_KEY=
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
ENABLE_YFINANCE=true

# =========================
# CONSENSO
# =========================
CONSENSUS_HIGH_MIN_SOURCES=3
CONSENSUS_MEDIUM_MIN_SOURCES=2
CONSENSUS_HIGH_MAX_DIVERGENCE_PCT=0.35
CONSENSUS_MEDIUM_MAX_DIVERGENCE_PCT=0.85
CONSENSUS_BLOCK_MAX_DIVERGENCE_PCT=1.50

# =========================
# KUSPIT / SIC
# =========================
KUSPIT_FILTER_MODE=tag

# =========================
# IA BAJO DEMANDA
# =========================
AI_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1/responses
OPENAI_TIMEOUT_SECONDS=60

# =========================
# PERSISTENCIA
# =========================
DATA_DIR=./data
DB_PATH=./data/scanner_global.db
UNIVERSE_PATH=./data/universe_global.csv
KUSPIT_LIST_PATH=./data/kuspit_watchlist.csv
BACKTEST_HORIZON_DAYS=20
DUPLICATE_SIGNAL_WINDOW_HOURS=12

# =========================
# TELEGRAM OPCIONAL
# =========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
